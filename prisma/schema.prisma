generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Employee {
  id         Int      @id @default(autoincrement())
  employeeNo String   @unique
  name       String
  email      String?
  password   String
  isAdmin    Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  applications Application[]
  wins         LotteryResult[]
}

model Game {
  id        Int      @id @default(autoincrement())
  date      DateTime
  dayOfWeek String
  opponent  String
  startTime String
  month     Int

  firstChoiceApps  Application[] @relation("FirstChoice")
  secondChoiceApps Application[] @relation("SecondChoice")
  thirdChoiceApps  Application[] @relation("ThirdChoice")
  result           LotteryResult?
}

model ApplicationPeriod {
  id        Int      @id @default(autoincrement())
  year      Int
  month     Int
  startDate DateTime
  endDate   DateTime
  isOpen    Boolean  @default(false)
  isDrawn   Boolean  @default(false)
  createdAt DateTime @default(now())

  applications Application[]

  @@unique([year, month])
}

model Application {
  id             Int      @id @default(autoincrement())
  employeeId     Int
  periodId       Int
  firstChoiceId  Int
  secondChoiceId Int?
  thirdChoiceId  Int?
  createdAt      DateTime @default(now())

  employee     Employee          @relation(fields: [employeeId], references: [id])
  period       ApplicationPeriod @relation(fields: [periodId], references: [id])
  firstChoice  Game              @relation("FirstChoice", fields: [firstChoiceId], references: [id])
  secondChoice Game?             @relation("SecondChoice", fields: [secondChoiceId], references: [id])
  thirdChoice  Game?             @relation("ThirdChoice", fields: [thirdChoiceId], references: [id])

  @@unique([employeeId, periodId])
}

model LotteryResult {
  id         Int      @id @default(autoincrement())
  gameId     Int      @unique
  employeeId Int
  priority   Int // 1=第1希望, 2=第2希望, 3=第3希望
  createdAt  DateTime @default(now())

  game     Game     @relation(fields: [gameId], references: [id])
  employee Employee @relation(fields: [employeeId], references: [id])
}
